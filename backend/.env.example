# =============================================
# ForensicShield Lite — Variables de Entorno
# Copia este archivo a .env y rellena los valores
# NUNCA subas .env al repositorio
# =============================================

# Base de datos PostgreSQL
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/forensicshield_db

# JWT — Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_SEGURA_DE_64_CARACTERES
ALGORITHM=HS256
TOKEN_EXPIRE_MINUTES=60

# Cookies — Usar True en producción con HTTPS
COOKIE_SECURE=false

# Control de intentos de login
MAX_INTENTOS_LOGIN=5
VENTANA_BLOQUEO_MINUTOS=15

# Mikrotik (opcional)
MIKROTIK_HOST=192.168.1.1
MIKROTIK_USER=admin
MIKROTIK_PASS=CAMBIA_ESTO
